# LinkedIn Profile Analyzer Environment Variables
# Copy this file to .env and add your actual API keys

# LinkedIn API Configuration
VITE_LINKEDIN_API_KEY=your_linkedin_api_key_here
VITE_LINKEDIN_API_URL=https://api.linkedin.com/v2

# Google OAuth Configuration (if needed)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# OpenAI API for AI Analysis (if using)
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Application Configuration
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:3000/api

